{
    "name": "flowforge",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "npx serve src",
        "test": "vitest run",
        "test:watch": "vitest",
        "format": "prettier --write \"src/**/*.{html,css,js}\" \"tests/**/*.js\"",
        "format:check": "prettier --check \"src/**/*.{html,css,js}\" \"tests/**/*.js\""
    },
    "devDependencies": {
        "prettier": "^3.3.0",
        "serve": "^14.2.0",
        "vitest": "^2.1.0"
    }
}